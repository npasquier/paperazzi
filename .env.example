# Paperazzi environment variables.
# Copy this file to .env.local and fill in any values you have.
# All variables are OPTIONAL — the app will run without them — but
# supplying MAIL_ID puts you in OpenAlex's "polite pool" with higher
# rate limits.

# Email passed to OpenAlex via the `mailto=` query param on server-side
# requests. Joins the polite pool. See:
# https://docs.openalex.org/how-to-use-the-api/api-overview#the-polite-pool
MAIL_ID=

# Same email but exposed to the browser, used by client-side fetches
# (e.g. fetching a paper's abstract from the detail modal). Must start
# with NEXT_PUBLIC_ to be inlined into the client bundle.
NEXT_PUBLIC_MAIL_ID=

# Legacy single OpenAlex API key. Paperazzi will include this in
# rotation automatically if OPENALEX_KEYS is not set (or merge it in
# if both are set).
OPEN_ALEX_API_KEY=

# Comma-separated list of OpenAlex API keys. The /api/search route
# rotates through these to spread load if you're hitting rate limits.
# Example: OPENALEX_KEYS=key1,key2,key3
OPENALEX_KEYS=

# Shared secret protecting /api/openalex/usage (the Cmd/Ctrl+Shift+U
# usage modal). The route exposes per-key spend and triggers one
# upstream call per key per hit, so in production it stays disabled
# until this is set. The modal prompts for the token and sends it via
# the x-usage-token header. Generate one with e.g.:
#   openssl rand -hex 32
# Leave empty in local development to keep the endpoint open there.
USAGE_API_TOKEN=
